{
  "name": "@code4js/eval-box",
  "version": "1.0.0",
  "description": "Secure, extensible JavaScript expression evaluation sandbox",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "eval",
    "expression",
    "sandbox",
    "safe",
    "parser",
    "evaluate",
    "math"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
